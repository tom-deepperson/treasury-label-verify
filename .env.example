REVIEWER_USERNAME=treasury
REVIEWER_PASSWORD=change-me-before-deploy

# Optional admin login: unlimited tests on hosted deploy (keep private)
DEVELOPER_USERNAME=developer
DEVELOPER_PASSWORD=

# Random string for signed login cookies. Generate locally:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-random-32-bytes

# Local dev: unlimited tests, skip OCR warmup on startup (first verify still loads models)
MAX_TESTS=0
WARM_OCR=0
USAGE_STORE=file
USAGE_FILE=data/usage_count.json

# OCR backend: vision (default on Cloud Run), easyocr, or paddle
OCR_BACKEND=vision
# Cheap local backend used for rotation/skew sweeps when OCR_BACKEND=vision
ROTATION_OCR_BACKEND=easyocr

# Field extraction: 0 = OCR parser only, 1 = LLM rescue on compare FAIL or REVIEW (requires API keys)
USE_LLM=1

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Gemini model for LLM rescue on compare FAIL (low latency default: gemini-3.1-flash-lite)
# GEMINI_MODEL=gemini-3.1-flash-lite

# Only required if USAGE_STORE=firestore on Cloud Run.
GOOGLE_CLOUD_PROJECT=gen-lang-client-X1234567890

# Optional deploy region (default us-east1)
# DEPLOY_REGION=us-east1

# Optional: Cloud Run URL for scripts/smoke_test_live.py
# DEPLOY_URL=https://your-service-REGION.a.run.app
