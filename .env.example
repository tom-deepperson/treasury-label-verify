REVIEWER_USERNAME=treasury
REVIEWER_PASSWORD=change-me-before-deploy

# Optional admin login: unlimited tests on hosted deploy (keep private)
DEVELOPER_USERNAME=developer
DEVELOPER_PASSWORD=

# Random string for signed login cookies. Generate locally:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-random-32-bytes

MAX_TESTS=10
USAGE_STORE=file
USAGE_FILE=data/usage_count.json

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Only required if USAGE_STORE=firestore on Cloud Run.
GOOGLE_CLOUD_PROJECT=gen-lang-client-X1234567890

# Optional deploy region (default us-east1)
# DEPLOY_REGION=us-east1

# Optional: Cloud Run URL for scripts/smoke_test_live.py
# DEPLOY_URL=https://your-service-REGION.a.run.app
